{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ori's mania utils",
  "version": "0.3.0",
  "identifier": "com.orismaniautils.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ori's mania utils",
        "width": 1280,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 760,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "resources": [
      "../overlays/"
    ],
    "icon": [

      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
